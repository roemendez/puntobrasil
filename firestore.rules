rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Por ahora: acceso abierto (solo para desarrollo inicial).
    // IMPORTANTE: antes de publicar en producción, reemplaza estas reglas
    // por autenticación real (Firebase Auth).

    match /{document=**} {
      allow read, write: if true;
    }

    // ─── Reglas de producción sugeridas (descomenta cuando tengas Firebase Auth) ───
    // match /config/{doc} {
    //   allow read, write: if request.auth != null;
    // }
    // match /inventario/{sku} {
    //   allow read, write: if request.auth != null;
    // }
    // match /clientes/{id} {
    //   allow read, write: if request.auth != null;
    // }
    // match /ventas/{id} {
    //   allow read, write: if request.auth != null;
    // }
    // match /abonos/{id} {
    //   allow read, write: if request.auth != null;
    // }
    // match /movimientos_stock/{id} {
    //   allow read, write: if request.auth != null;
    // }
    // match /movimientos_financieros/{id} {
    //   allow read, write: if request.auth != null;
    // }
  }
}
